includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app

    level: 5

    ignoreErrors:
        - '#Parameter \#1 \$view of function view expects view-string#'
        - '#Using nullsafe property access.*on left side of.*is unnecessary#'
        - '#Call to static method where\(\) on an unknown class#'